{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.clickhouse",
  "name": "ClickHouse Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "ClickHouse Connector contributes the ClickHouse database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-clickhouse",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "clickhouse.connector",
        "engine": "clickhouse",
        "label": "ClickHouse",
        "aliases": [
          "clickhouse",
          "ClickHouse"
        ],
        "defaultPort": 8123,
        "wire": "clickhouse",
        "module": "clickhouse.driver",
        "features": [
          "metadata",
          "sql",
          "streaming",
          "explain",
          "timeSeries",
          "timeBuckets",
          "latestValue",
          "queryTemplates",
          "visualization"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "clickhouse",
            "wire": "clickhouse",
            "port": 8123,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "hostPort",
              "connectionString"
            ],
            "defaultPort": 8123,
            "fields": [
              {
                "id": "host",
                "label": "Host",
                "type": "string",
                "profileField": "host",
                "required": true
              },
              {
                "id": "port",
                "label": "Port",
                "type": "number",
                "profileField": "port",
                "default": 8123
              },
              {
                "id": "database",
                "label": "Database",
                "type": "string",
                "profileField": "database"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "host",
              "label": "Host",
              "type": "string",
              "profileField": "host",
              "required": true
            },
            {
              "id": "port",
              "label": "Port",
              "type": "number",
              "profileField": "port",
              "default": 8123
            },
            {
              "id": "database",
              "label": "Database",
              "type": "string",
              "profileField": "database"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "none",
              "label": "No authentication",
              "kind": "none",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "userPassword",
              "label": "User/password",
              "kind": "userPassword",
              "secretPurposes": [
                "password"
              ],
              "fields": [
                {
                  "id": "user",
                  "label": "User",
                  "type": "string",
                  "profileField": "user"
                },
                {
                  "id": "password",
                  "label": "Password",
                  "type": "secret",
                  "secretPurpose": "password",
                  "profileField": "password"
                }
              ]
            },
            {
              "id": "bearerToken",
              "label": "Bearer token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "clientCertificate",
              "label": "Client certificate / mTLS",
              "kind": "certificate",
              "secretPurposes": [
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "clientCertificate",
                  "label": "Client certificate",
                  "type": "pem"
                },
                {
                  "id": "clientPrivateKey",
                  "label": "Client private key",
                  "type": "pem",
                  "secretPurpose": "privateKey"
                },
                {
                  "id": "clientPrivateKeyPassphrase",
                  "label": "Private key passphrase",
                  "type": "secret",
                  "secretPurpose": "privateKeyPassphrase"
                }
              ]
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "password",
            "token",
            "privateKey",
            "privateKeyPassphrase"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": false,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "clickhouse"
          ],
          "customDriverOptions": true
        },
        "experience": {
          "schemaVersion": 1,
          "domains": [
            "timeSeries"
          ],
          "inspiredBy": [
            "ClickHouse SQL console",
            "time bucketing",
            "latest-point analytics"
          ],
          "resultViews": [
            "timeChart",
            "table",
            "heatmap"
          ],
          "objectTypes": [
            "tables",
            "columns",
            "partitions",
            "projections",
            "materializedViews"
          ],
          "workflows": [
            {
              "id": "time-bucket",
              "label": "Bucketed aggregate",
              "description": "Group high-volume events into chart windows.",
              "resultView": "timeChart",
              "templateIds": [
                "time-clickhouse-bucket"
              ]
            },
            {
              "id": "time-latest",
              "label": "Latest event per key",
              "description": "Use argMax-style aggregates for latest values.",
              "resultView": "table",
              "templateIds": [
                "time-clickhouse-latest"
              ]
            }
          ],
          "queryTemplates": [
            {
              "id": "time-clickhouse-bucket",
              "label": "Bucketed aggregate",
              "language": "sql",
              "description": "Aggregate events into one-minute windows.",
              "insertText": "SELECT\n  toStartOfInterval(timestamp, INTERVAL 1 minute) AS bucket,\n  count() AS events\nFROM events\nWHERE timestamp >= now() - INTERVAL 1 HOUR\nGROUP BY bucket\nORDER BY bucket;",
              "parameters": [],
              "resultView": "timeChart"
            },
            {
              "id": "time-clickhouse-latest",
              "label": "Latest per key",
              "language": "sql",
              "description": "Return latest values per series key.",
              "insertText": "SELECT\n  series_id,\n  argMax(value, timestamp) AS latest_value,\n  max(timestamp) AS latest_timestamp\nFROM readings\nGROUP BY series_id;",
              "parameters": [],
              "resultView": "table"
            }
          ],
          "inspectorHints": [
            {
              "id": "time-partition",
              "label": "Partition key",
              "description": "Show partition expressions and TTL settings near each table."
            },
            {
              "id": "time-projection",
              "label": "Projection hint",
              "description": "Surface projections and materialized views useful for time buckets."
            }
          ]
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "clickhouse.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
